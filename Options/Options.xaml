<ResourceDictionary
    x:Class="NinaTheSkyX.Options.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NinaTheSkyX">

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!--
        Convention NINA : DataTemplate keyé "<AssemblyTitle>_Options".
        AssemblyTitle = "TheSkyX Guider" → clé = "TheSkyX Guider_Options".
    -->
    <DataTemplate x:Key="TheSkyX Guider_Options">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10" Orientation="Vertical"
                        DataContext="{x:Static local:Plugin.Options}">

                <!-- TheSkyX TCP -->
                <TextBlock Text="TheSkyX 64 — connexion TCP" FontWeight="Bold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hôte" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="0" Grid.Column="1"
                               Text="{Binding TheSkyXHost, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Port TCP" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="1"
                               Text="{Binding TheSkyXPort, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Exposition guide (s)" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding TheSkyXGuideExposureSeconds, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Subframe guideur (px)" VerticalAlignment="Center"
                               ToolTip="Taille du subframe carré centré sur l'étoile guide, activé avant Calibrate(). 0 = désactivé."/>
                    <TextBox   Grid.Row="3" Grid.Column="1"
                               Text="{Binding TheSkyXGuiderSubframeSize, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <CheckBox Content="Logs détaillés (debug)"
                          IsChecked="{Binding DebugLogging}" Margin="0,0,0,12"/>

                <!-- Sélection auto de l'étoile guide par ADU (Phase 6) -->
                <TextBlock Text="Sélection auto de l'étoile guide (ADU)" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="11" Foreground="Gray"
                           Text="Au démarrage du guidage, le plugin prend une image guide et choisit une étoile NON saturée dont le pic ADU est le plus proche de l'optimum, dans l'intervalle min–max. Échelle brute du capteur (dépend de la caméra guide / profondeur de bits)."/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ADU min" VerticalAlignment="Center"
                               ToolTip="Pic ADU minimum : en dessous, étoile trop faible (SNR insuffisant)."/>
                    <TextBox   Grid.Row="0" Grid.Column="1"
                               Text="{Binding GuideStarMinADU, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ADU optimum" VerticalAlignment="Center"
                               ToolTip="Pic ADU cible : l'étoile dont le pic est le plus proche est retenue."/>
                    <TextBox   Grid.Row="1" Grid.Column="1"
                               Text="{Binding GuideStarOptimumADU, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ADU max" VerticalAlignment="Center"
                               ToolTip="Pic ADU maximum (sous la saturation) : au-dessus, étoile rejetée."/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding GuideStarMaxADU, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- Wizard calibration guidage -->
                <GroupBox Header="Calibration du guidage TheSkyX" Margin="0,0,0,12" Padding="8"
                          DataContext="{Binding GuiderCalibration}">
                    <StackPanel>

                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" FontSize="11"
                                   Text="Assistant de calibration guidage en deux passes (Est puis Ouest, 0° Dec). NINA pointe la monture automatiquement — la prise de vue guide démarre immédiatement après le pointage."/>

                        <!-- Exposition calibration -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Exposition images (s)"
                                       VerticalAlignment="Center"
                                       ToolTip="Exposition pour les images de prévisualisation et de calibration. 3–8 s typique."/>
                            <Slider Grid.Column="1" Margin="0,0,8,0"
                                    Minimum="1" Maximum="30"
                                    SmallChange="1" LargeChange="5"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding CalibrationExposureSeconds, Mode=TwoWay}"/>
                            <TextBox Grid.Column="2" IsReadOnly="True"
                                     Text="{Binding CalibrationExposureSeconds, StringFormat=F0, Mode=OneWay}"/>
                        </Grid>

                        <TextBlock Text="{Binding StatusText}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                   FontSize="13" FontWeight="SemiBold" FontStyle="Italic"
                                   Foreground="{DynamicResource PrimaryBrush}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Opération en cours dans TheSkyX / NINA..."
                                       FontStyle="Italic" Foreground="Gray" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Content="🎯 Calibrer guidage (Est + Ouest)"
                                Command="{Binding StartCommand}"
                                Visibility="{Binding ShowStartButton, Converter={StaticResource BoolToVis}}"
                                Padding="12,5" Margin="0,0,0,4" HorizontalAlignment="Left"
                                FontWeight="Bold"/>

                        <Button Content="{Binding ConfirmButtonContent}"
                                Command="{Binding ConfirmCommand}"
                                Visibility="{Binding ShowConfirmButton, Converter={StaticResource BoolToVis}}"
                                Padding="12,5" Margin="0,0,0,4" HorizontalAlignment="Left"
                                FontWeight="Bold"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="{Binding ShowImageValidationButtons, Converter={StaticResource BoolToVis}}">
                            <Button Content="✅ Image OK"
                                    Command="{Binding ImageOkCommand}"
                                    Padding="10,5" Margin="0,0,8,0" FontWeight="Bold"/>
                            <Button Content="❌ Déplacer en RA (5') et retenter"
                                    Command="{Binding JogAndRetryCommand}"
                                    Padding="10,5"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="{Binding ShowCalibValidationButtons, Converter={StaticResource BoolToVis}}">
                            <Button Content="✅ Calibration OK"
                                    Command="{Binding CalibrationOkCommand}"
                                    Padding="10,5" Margin="0,0,8,0" FontWeight="Bold"/>
                            <Button Content="🔄 Recommencer (reprend depuis la prise de vue)"
                                    Command="{Binding RetryCalibrationCommand}"
                                    Padding="10,5"/>
                        </StackPanel>

                        <Button Content="⏹ Annuler la calibration"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVis}}"
                                Padding="10,4" Margin="0,4,0,0" HorizontalAlignment="Left"/>

                        <TextBlock Text="{Binding LastCalibrationInfo}"
                                   Margin="0,8,0,0" FontSize="11" Foreground="Gray"
                                   TextWrapping="Wrap"/>

                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

    </DataTemplate>

</ResourceDictionary>
